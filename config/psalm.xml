<?xml version="1.0"?>
<psalm
    errorLevel="1"
    resolveFromConfigFile="true"
    findUnusedCode="true"
    findUnusedBaselineEntry="true"
>
    <projectFiles>
        <directory name="../src"/>
        <directory name="../tests"/>
        <ignoreFiles>
            <directory name="../vendor"/>
            <directory name="../build"/>
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <UnusedClass>
            <errorLevel type="suppress">
                <directory name="../tests"/>
            </errorLevel>
        </UnusedClass>
        <UndefinedMethod>
            <errorLevel type="suppress">
                <referencedMethod name="FFI::ioctl"/>
            </errorLevel>
        </UndefinedMethod>
        <UndefinedPropertyFetch>
            <errorLevel type="suppress">
                <referencedProperty name="FFI\CData::$ws_col"/>
            </errorLevel>
        </UndefinedPropertyFetch>
        <MixedAssignment>
            <errorLevel type="suppress">
                <file name="../tests/CellRowTest.php"/>
                <file name="../tests/FigletTest.php"/>
            </errorLevel>
        </MixedAssignment>
        <MixedArgument>
            <errorLevel type="suppress">
                <file name="../tests/FigletTest.php"/>
            </errorLevel>
        </MixedArgument>
        <MixedArgumentTypeCoercion>
            <errorLevel type="suppress">
                <file name="../tests/FigletTest.php"/>
            </errorLevel>
        </MixedArgumentTypeCoercion>
    </issueHandlers>
</psalm>
